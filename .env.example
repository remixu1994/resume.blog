# Canonical site origin used by metadata, robots.txt, and sitemap.xml.
SITE_URL=https://resume.blog

# ReleaseOps deploy gate inputs.
RELEASEOPS_MIGRATIONS_CHECKED=true
RELEASEOPS_HEALTHCHECK_URL=https://resume.blog/api/health
RELEASEOPS_HEALTHCHECK_SAMPLES=3
RELEASEOPS_HEALTHCHECK_TIMEOUT_MS=5000
RELEASEOPS_TEST_COMMAND="npm test"

# Local development: leave these unset to use data/blog.sqlite.
# Production PostgreSQL example:
# BLOG_DB_PROVIDER=postgres
# BLOG_DATABASE_URL=postgresql://blog_user:change-me@db.example.com:5432/resume_blog

# Admin publishing (required for /admin)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me
# ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
# ADMIN_APP_URL=https://example.com

# S3-compatible blog asset storage
# BLOG_ASSET_S3_ENDPOINT=https://s3.example.com
# BLOG_ASSET_S3_REGION=auto
# BLOG_ASSET_S3_BUCKET=resume-blog-assets
# BLOG_ASSET_S3_ACCESS_KEY_ID=change-me
# BLOG_ASSET_S3_SECRET_ACCESS_KEY=change-me
# BLOG_ASSET_PUBLIC_BASE_URL=https://assets.example.com
# BLOG_ASSET_S3_FORCE_PATH_STYLE=false

# Production MySQL example:
# BLOG_DB_PROVIDER=mysql
# BLOG_DATABASE_URL=mysql://blog_user:change-me@db.example.com:3306/resume_blog
