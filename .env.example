# Canonical site origin used by metadata, robots.txt, and sitemap.xml.
SITE_URL=https://resume.blog

# ReleaseOps deploy gate inputs.
RELEASEOPS_MIGRATIONS_CHECKED=true
RELEASEOPS_HEALTHCHECK_URL=https://resume.blog/api/health
RELEASEOPS_HEALTHCHECK_SAMPLES=3
RELEASEOPS_HEALTHCHECK_TIMEOUT_MS=5000
RELEASEOPS_TEST_COMMAND="npm test"
